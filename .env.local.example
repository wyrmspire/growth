# ─── GrowthOps OS — Environment Variables ────────────────────────
# Copy this file to .env.local and fill in your keys.
# In mock-safe mode (all vars empty), every feature still works with
# deterministic local data — no live API calls are made.

# ─── Google AI (Gemini) ──────────────────────────────────────────
# Required for live Genkit flows (offer strategist, copy coach, reply coach).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model to use (optional — defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Local flow server port (optional — defaults to 3400)
PORT=3400

# ─── Meta (Facebook / Instagram) ─────────────────────────────────
# Create an app at https://developers.facebook.com/apps/
# Generate a Page Access Token via the Graph API Explorer
META_ACCESS_TOKEN=

# ─── LinkedIn ────────────────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps
# Use the OAuth 2.0 flow to obtain an access token
LINKEDIN_ACCESS_TOKEN=

# ─── X (Twitter) ─────────────────────────────────────────────────
# Create a project at https://developer.twitter.com/en/portal/dashboard
# Copy the API Key and API Secret from the "Keys and Tokens" tab
X_API_KEY=
X_API_SECRET=

# ─── Email / SMTP ────────────────────────────────────────────────
# Your SMTP provider (e.g. smtp.gmail.com, smtp.sendgrid.net)
# For Gmail: enable "App passwords" at https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PASS=

# ─── Reddit ──────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps
# Choose "script" type for personal use, "web app" for OAuth
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── TikTok ──────────────────────────────────────────────────────
# Apply for a developer account at https://developers.tiktok.com/
# Create an app and get your Client Key + Client Secret
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── Instagram (separate token if not using Meta unified token) ──
# Same developer portal as Meta: https://developers.facebook.com/apps/
# Use the Instagram Basic Display API or Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=

# ─── YouTube ─────────────────────────────────────────────────────
# Enable YouTube Data API v3 at https://console.cloud.google.com/apis/credentials
# Create an API key in the Google Cloud Console
YOUTUBE_API_KEY=

# ─── Substack ────────────────────────────────────────────────────
# Substack does not have a public API. This token is a placeholder
# for future custom integration (e.g. email-to-publish workflow).
SUBSTACK_API_TOKEN=

# ─── Rate Limits ─────────────────────────────────────────────────
# Per-platform daily request limit for publish operations.
# Default is 50/day/platform. Override per platform:
# RATE_LIMIT_META=50
# RATE_LIMIT_LINKEDIN=50
# RATE_LIMIT_X=50
# RATE_LIMIT_EMAIL=100

# ─── Notes ───────────────────────────────────────────────────────
# When all credential env vars are empty, the app runs in mock-safe
# mode with deterministic local responses. No errors are thrown.
# Credentials set via the /api/credentials/:platform endpoint are
# stored in-memory and reset on server restart.
