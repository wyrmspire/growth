# Copy this file to .env.local and fill in your keys

# Google AI (Gemini) — required for live Genkit flows
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model to use (optional — defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# When GEMINI_API_KEY is empty, all flows run in mock-safe mode
# (no AI calls, deterministic coaching responses).
