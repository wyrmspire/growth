# Copy this file to .env.local and fill in your keys

# Google AI (Gemini) â€” required for live Genkit flows
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model to use (optional â€” defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Local flow server port (optional)
PORT=3400

# When GEMINI_API_KEY is empty, all flows run in mock-safe mode
# (no AI calls, deterministic coaching responses).
